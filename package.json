{
  "name": "stock-data",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "download:tickers": "tsx src/data-fetcher/download-ticker-list.ts",
    "download:history": "tsx src/data-fetcher/download-price-history.ts",
    "db:build": "tsx src/data-fetcher/build-duckdb.ts",
    "db:update-metrics": "tsx src/data-fetcher/update-fundamental-metrics.ts",
    "db:update-profiles": "tsx src/data-fetcher/update-qualitative-profiles.ts",
    "charts:generate": "tsx src/chart-generator/batch.ts",
    "all": "npm run download:tickers && npm run download:history && npm run db:build && npm run db:update-metrics && npm run db:update-profiles && npm run charts:generate",
    "build:static": "tsx src/static-builder/build.ts",
    "all:static": "npm run all && npm run build:static",
    "preview": "npx -y http-server dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.3-r.3",
    "alpinejs": "^3.15.12",
    "edinet-ts": "^1.1.17",
    "p-limit": "^6.2.0",
    "sharp": "^0.35.3",
    "xlsx": "^0.18.5",
    "yahoo-finance2": "^3.15.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.2.3"
  }
}
